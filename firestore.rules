// Firestore Security Rules - Authentication phase
//
// These rules say: "you may only write to your own user/profile document,
// but any logged-in account can read profiles" (needed later so students
// can browse startup profiles, and startups can view student profiles
// when reviewing applicants).
//
// HOW TO APPLY THESE:
// Firebase console -> Firestore Database -> Rules tab -> paste this in ->
// Publish.
//
// We will extend this file again once we add the "opportunities" and
// "applications" collections in later development steps.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} -> small record: { uid, email, role }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // students/{uid} -> full student profile
    match /students/{studentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == studentId;
    }

    // startups/{uid} -> full startup profile
    match /startups/{startupId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == startupId;
    }
  }
}
